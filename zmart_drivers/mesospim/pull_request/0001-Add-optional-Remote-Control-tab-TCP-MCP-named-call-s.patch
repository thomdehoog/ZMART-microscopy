+            "etl_l_amplitude", "etl_l_offset", "etl_r_delay_%",
+            "etl_r_ramp_rising_%", "etl_r_ramp_falling_%",
+            "etl_r_amplitude", "etl_r_offset")
+    core.state_request_handler(_settings_from_args(a, keys))
