{
  "schema_version": 1,
  "source": "defaults",
  "constraints": {
    "stage.x": {
      "min": 0.0,
      "max": 25000.0
    },
    "stage.y": {
      "min": 0.0,
      "max": 25000.0
    },
    "stage.z": {
      "min": 0.0,
      "max": 25000.0
    },
    "stage.f": {
      "min": 0.0,
      "max": 25000.0
    },
    "stage.theta": {
      "min": -360.0,
      "max": 360.0
    }
  },
  "functions": {
    "set_origin": null,
    "set_xyz": {
      "x": "@stage.x",
      "y": "@stage.y",
      "z": "@stage.z"
    },
    "set_state": null,
    "run_procedure": {
      "f": "@stage.f",
      "theta": "@stage.theta"
    },
    "acquire": {
      "z_start": "@stage.z",
      "z_end": "@stage.z"
    }
  }
}
