; ZEN API gateway connection settings.
; Copy to config.ini and fill in. The control-token is generated by the ZEN API
; Gateway (system-tray icon or --generate-global-control-token) and lives at
;   %PROGRAMDATA%\Carl Zeiss\ZEN APIGateway\GlobalControlToken.txt
; cert_file is the gateway CA .pem (resolved relative to this file if not absolute).
[api]
host = 127.0.0.1
port = 5002
cert_file = C:\ProgramData\Carl Zeiss\ZEN APIGateway\Certificates\ZEN APIPersonalSigningRootCA.pem
control-token = PASTE_YOUR_GLOBAL_CONTROL_TOKEN_HERE
